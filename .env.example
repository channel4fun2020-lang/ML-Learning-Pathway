# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production

# Database
DATABASE_URL=sqlite:///ml_pathway.db
# For PostgreSQL: postgresql://user:password@localhost/ml_pathway

# Email (for notifications)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# AWS S3 (for file uploads)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# API Keys
KAGGLE_API_KEY=
GITHUB_API_TOKEN=

# Application
APP_NAME=ML Learning Pathway
APP_URL=http://localhost:5000
